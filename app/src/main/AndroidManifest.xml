<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Draw the blur overlay above all other apps. One-time settings toggle, persists. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Lets us read which app is currently in the foreground, for per-app exclusions.
         Granted via a special Settings screen, one-time, persists. -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- Keep the watcher alive as a foreground service. Auto-granted, no dialog. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Android 13+ only. One-time runtime dialog, persists once granted. No-op on Android 10. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Let the service auto-restart after the phone reboots, so you don't have to relaunch it. -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:allowBackup="true"
        android:icon="@android:drawable/ic_lock_idle_lock"
        android:label="AppBlur"
        android:theme="@style/Theme.AppBlur">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".AppListActivity"
            android:exported="false"
            android:label="Excluded apps" />

        <service
            android:name=".BlurOverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="privacy_screen_blur" />
        </service>

        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
